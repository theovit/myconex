# MYCONEX — Environment Configuration Template
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ─── Discord ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=                          # Required for discord/full mode. Get from Discord Developer Portal → Bot → Reset Token
DISCORD_APPLICATION_ID=1469408384070586432  # Your Discord application ID
DISCORD_HOME_CHANNEL=                       # Default channel ID for bot delivery
DISCORD_HOME_CHANNEL_NAME=general
DISCORD_REQUIRE_MENTION=false               # true = bot only responds when @mentioned
DISCORD_FREE_RESPONSE_CHANNELS=            # Comma-separated channel IDs that bypass require_mention
DISCORD_AUTO_THREAD=false                   # true = create a thread per @mention
DISCORD_ALLOWED_USERS=                      # Comma-separated Discord user IDs; empty = allow all
DISCORD_ALLOW_BOTS=none                     # none | all | allowlist

# ─── LLM Backends ─────────────────────────────────────────────────────────────
MYCONEX_BACKEND=ollama                      # Default backend: ollama | llamacpp | lmstudio | litellm
OLLAMA_URL=http://localhost:11434           # Ollama inference endpoint
LLAMACPP_URL=                              # llama.cpp server URL (leave blank to disable)
LMSTUDIO_URL=                              # LM Studio URL (leave blank to disable)
LITELLM_URL=http://localhost:4000          # LiteLLM proxy URL

# ─── Mesh Services ────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222             # NATS messaging (required for multi-node mesh)
REDIS_URL=redis://localhost:6379           # Redis state store
QDRANT_URL=http://localhost:6333          # Qdrant vector store (RAG)

# ─── Node Identity ────────────────────────────────────────────────────────────
MYCONEX_NODE=                              # Node name in the mesh (auto-generated if blank)
MYCONEX_TIER=                              # Force tier: T1 | T2 | T3 | T4 (auto-detected if blank)

# ─── Context / Memory ─────────────────────────────────────────────────────────
MYCONEX_CONTEXT_BUDGET=16384              # Total token budget for RLM context
MYCONEX_MEMORY_DIR=~/.myconex/memory     # Persistent memory directory
MYCONEX_MEMORY_NAMESPACE=global          # Memory namespace

# ─── API Server ───────────────────────────────────────────────────────────────
MYCONEX_API_HOST=127.0.0.1               # API server host (use 0.0.0.0 to expose externally)
MYCONEX_API_PORT=8765                    # API server port

# ─── Logging ──────────────────────────────────────────────────────────────────
MYCONEX_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ─── Integrations (optional) ──────────────────────────────────────────────────
OPENROUTER_API_KEY=                      # OpenRouter API key (MoE chain fallback)
GMAIL_CLIENT_ID=                         # Gmail OAuth client ID (gmail_reader.py)
GMAIL_CLIENT_SECRET=                     # Gmail OAuth client secret
FABRIC_API_KEY=                          # Fabric AI API key
DLAM_API_KEY=                            # DLAM API key
